# ─────────────────────────────────────────
# Piaazo Agency — Environment Variables
# Copy this file to .env.local and fill in
# DO NOT commit .env.local to git
# ─────────────────────────────────────────

# Site metadata
NEXT_PUBLIC_SITE_NAME="Client Name"
NEXT_PUBLIC_SITE_URL="https://clientdomain.com"

# Analytics (optional)
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_GTM_ID=""

# Error tracking
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Database (if needed)
DATABASE_URL=""

# Email / contact form
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
CONTACT_FORM_TO=""

# CMS (if using Contentful, Sanity, etc.)
CONTENTFUL_SPACE_ID=""
CONTENTFUL_ACCESS_TOKEN=""

# Payments (if needed)
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
